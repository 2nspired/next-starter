# ============================================
# SUPABASE
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# ============================================
NEXT_PUBLIC_SUPABASE_URL=           # Project URL (e.g. https://xxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # anon/public key
SUPABASE_SERVICE_ROLE_KEY=          # service_role key (server-only, never expose)

# ============================================
# DATABASE
# Get these from: Supabase Dashboard → Settings → Database
# ============================================
DATABASE_URL=                       # Pooler connection string (Transaction mode, port 6543)
                                    # Used at RUNTIME by @prisma/adapter-pg
DIRECT_URL=                         # Direct connection string (port 5432)
                                    # Used for MIGRATIONS only (prisma migrate)

# ============================================
# APP
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # Your app URL
NODE_ENV=development
